{
  "name": "@home-ktv/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@home-ktv/domain": "workspace:*",
    "@home-ktv/player-contracts": "workspace:*",
    "@home-ktv/protocol": "workspace:*",
    "chokidar": "5.0.0",
    "fastify": "5.8.5",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/pg": "^8.20.0",
    "tsx": "4.21.0",
    "vitest": "^4.1.5"
  }
}
