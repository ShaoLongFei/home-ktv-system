{
  "name": "home-ktv-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:local": "bash scripts/dev-local.sh",
    "db:migrate": "pnpm -F @home-ktv/api migrate",
    "seed:demo-song": "node scripts/seed-demo-song.mjs",
    "ui:visual-check": "node scripts/ui-visual-check.mjs",
    "ui:visual-check:test": "node --test scripts/ui-visual-check.test.mjs",
    "tv:visual-check": "node scripts/tv-visual-check.mjs",
    "hot-songs:sources": "pnpm -F @home-ktv/hot-songs collect-sources",
    "hot-songs:normalize": "pnpm -F @home-ktv/hot-songs normalize",
    "hot-songs:sources:test": "pnpm -F @home-ktv/hot-songs test",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  }
}
